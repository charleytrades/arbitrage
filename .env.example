# Polygon EOA private key (no 0x prefix)
PRIVATE_KEY=your_polygon_private_key_here

# Polymarket CLOB host
POLYMARKET_HOST=https://clob.polymarket.com
POLYMARKET_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market

# Binance WebSocket
BINANCE_WS_URL=wss://stream.binance.com:9443/ws

# Bybit WebSocket (multi-venue confirmation)
BYBIT_WS_URL=wss://stream.bybit.com/v5/public/spot

# Gamma API (market discovery)
GAMMA_API_URL=https://gamma-api.polymarket.com

# Telegram alerts
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Risk parameters (hardened)
MAX_BANKROLL_PERCENT=4.0
MAX_DAILY_LOSS_PERCENT=8.0
MAX_CONSECUTIVE_LOSSES=3
CONSECUTIVE_LOSS_COOLDOWN_SEC=1800
KELLY_FRACTION=0.25
MAX_CONCURRENT_BUCKETS=8

# Trading mode: backtest | paper_trade | live
TRADING_MODE=paper_trade

# Symbols to trade
SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT

# Strategy parameters (high-winrate 90%+ filter)
MOMENTUM_THRESHOLD=0.0035
MOMENTUM_WINDOW_START_SEC=15
MOMENTUM_WINDOW_END_SEC=45
LATENCY_EDGE_MS=500
CROSS_OUTCOME_THRESHOLD=0.99
MIN_SPREAD_PROFIT=0.005
VOLUME_CONFIRM_MULTIPLIER=1.5

# Order management
MIN_ORDER_SIZE=5.0
MAX_ORDER_SIZE=100.0
ORDER_TTL_SEC=60

# Market discovery interval
MARKET_REFRESH_INTERVAL_SEC=30

# Chain ID (137 = Polygon mainnet)
CHAIN_ID=137

# ── Drift BET (cross-platform arb) ──────────────
DRIFT_ENABLED=false
DRIFT_BET_API_URL=https://bet.drift.trade/api
DRIFT_MAINNET_RPC=https://api.mainnet-beta.solana.com
SOLANA_PRIVATE_KEY=your_solana_private_key_here
CROSS_PLATFORM_MIN_SPREAD=0.06
DRIFT_POLL_INTERVAL_SEC=5
