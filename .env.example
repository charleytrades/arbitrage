# Polygon EOA private key (no 0x prefix)
PRIVATE_KEY=your_polygon_private_key_here

# Polymarket CLOB host
POLYMARKET_HOST=https://clob.polymarket.com
POLYMARKET_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market

# Binance WebSocket
BINANCE_WS_URL=wss://stream.binance.com:9443/ws

# Gamma API (market discovery)
GAMMA_API_URL=https://gamma-api.polymarket.com

# Telegram alerts
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Risk parameters
MAX_BANKROLL_PERCENT=2.0
MAX_DAILY_LOSS_PERCENT=5.0
MAX_CONSECUTIVE_LOSSES=5
KELLY_FRACTION=0.25

# Trading mode: backtest | paper_trade | live
TRADING_MODE=paper_trade

# Symbols to trade
SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT

# Strategy parameters
MOMENTUM_THRESHOLD=0.0015
LATENCY_EDGE_MS=500
CROSS_OUTCOME_THRESHOLD=0.99
MIN_SPREAD_PROFIT=0.005

# Order sizing
MIN_ORDER_SIZE=5.0
MAX_ORDER_SIZE=100.0

# Chain ID (137 = Polygon mainnet)
CHAIN_ID=137
